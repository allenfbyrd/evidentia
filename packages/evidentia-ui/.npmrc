# Evidentia UI sits on bleeding-edge toolchain versions (TypeScript 6,
# React 19, Vite 8). Some otherwise-compatible dev tools still declare
# peer ranges that lag the latest TypeScript major (e.g.
# openapi-typescript's `peer typescript@^5.x`). The mismatch is
# cosmetic — these tools consume TS for type emission only and run fine
# on TS 6 — so accept legacy peer resolution rather than pin the whole
# project back to an older TypeScript.
legacy-peer-deps=true
